{
  "name": "ochoit",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "verify": "turbo run verify",
    "dev:web": "turbo run dev --filter=web",
    "deploy": "turbo run deploy --filter=@ochoit/infra",
    "destroy": "turbo run destroy --filter=@ochoit/infra"
  },
  "dependencies": {
    "@ochoit/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251213.0",
    "@ochoit/config": "workspace:*",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.15.0"
}
